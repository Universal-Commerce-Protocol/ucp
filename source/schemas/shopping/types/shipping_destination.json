{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucp.dev/schemas/shopping/types/shipping_destination.json",
  "title": "Shipping Destination",
  "description": "Shipping destination.",
  "type": "object",
  "ucp_shared_request": true,
  "allOf": [
    {
      "$ref": "../../common/types/postal_address.json"
    },
    {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "ID specific to this shipping destination.",
          "ucp_request": "optional"
        },
        "one_time_use": {
          "type": "boolean",
          "default": false,
          "ucp_request": "optional",
          "description": "Best-effort hint that this destination should not be retained beyond the immediate transaction (e.g., not added to the buyer's address book or marketing profile)."
        }
      },
      "required": [
        "id"
      ]
    }
  ]
}
